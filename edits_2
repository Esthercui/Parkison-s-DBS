# =========================
# Stage 2 budget sweep results collector
# =========================

BUDGETS = [10, 20, 30, 40]   # add 100 if you want
SEEDS_SWEEP = 30             # reduce if QAOA gets too slow

stage2_methods = {
    "Random": run_random,
    "GA": run_ga,
    "BO": run_bo if USE_BAYES_OPT else None,
    "CMA-ES": run_cma_es if USE_CMA_ES else None,
    "Surrogate (Exact)": run_surrogate_exact,
    "QAOA (p=1)": lambda cf, b, s: run_surrogate_qaoa(cf, b, s, p_layers=1),
    # optional if p=2 is stable:
    # "QAOA (p=2)": lambda cf, b, s: run_surrogate_qaoa(cf, b, s, p_layers=2),
}

stage2_budget_results = {}

for B in BUDGETS:
    print(f"\n{'='*60}\nSTAGE 2 BUDGET = {B}\n{'='*60}")
    stage2_budget_results[B] = {}
    for name, fn in stage2_methods.items():
        if fn is None:
            continue
        finals = []
        regrets = []
        for s in range(SEEDS_SWEEP):
            evals = fn(cost_flat, B, s)
            best = min([e[-1] for e in evals])   # last entry is cost
            finals.append(best)
            regrets.append(best - ground_truth["cost_star"])
        stage2_budget_results[B][name] = {
            "mean_final_cost": float(np.mean(finals)),
            "mean_regret": float(np.mean(regrets)),
            "std_regret": float(np.std(regrets)),
        }
        print(f"{name:20s} mean_regret={np.mean(regrets):.4f}  std_regret={np.std(regrets):.4f}")





#REGRET VS BUDGET FIGURE 
import numpy as np
import matplotlib.pyplot as plt

budgets = np.array(BUDGETS)

# Choose the methods you actually want shown
plot_methods = ["Random", "BO", "CMA-ES", "QAOA (p=1)", "GA"]

plt.figure(figsize=(8.5, 5.2))

for name in plot_methods:
    if name not in stage2_budget_results[budgets[0]]:
        continue
    means = np.array([stage2_budget_results[B][name]["mean_regret"] for B in budgets])
    stds  = np.array([stage2_budget_results[B][name]["std_regret"]  for B in budgets])

    plt.errorbar(
        budgets,
        means,
        yerr=stds,
        marker="o",
        capsize=3,
        linewidth=2,
        label=name
    )

plt.xticks(budgets)
plt.xlabel("Evaluation Budget B")
plt.ylabel("Mean Regret vs Ground Truth")
plt.title("Stage 2: Performance vs Budget (Mean ± Std)")
plt.grid(True, alpha=0.25)
plt.legend(fontsize=9)
plt.tight_layout()
plt.show()





